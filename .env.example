# Copy this file to .env.local and fill in the values. .env.local is gitignored.

# ---- Supabase (Milestone M0) ----
# Project Settings → Data API / API Keys in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER prefix with NEXT_PUBLIC_. Bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=

