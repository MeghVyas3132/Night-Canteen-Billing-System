# Copy this file to .env.local and fill in the values. .env.local is gitignored.

# ---- Supabase (Milestone M0) ----
# Project Settings → Data API / API Keys in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER prefix with NEXT_PUBLIC_. Bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Razorpay (Milestone M3 — start in Test Mode) ----
# Dashboard → Settings → API Keys → Generate Test Key (starts with rzp_test_).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Only needed once deployed (public URL) — Dashboard → Settings → Webhooks.
RAZORPAY_WEBHOOK_SECRET=
